#pragma once
#include "Nodo.h"
#include "Cancion.h"
class Cola
{
private:
	Nodo* inicio;
	Nodo* fin;
	int cantidad;
public:
	Cola() {
		inicio = NULL;
		fin = NULL;
		cantidad = 0;
	}

	bool estaVacia() {
		return inicio == NULL;
	}

	bool estaLlena() {
		return cantidad == 5;
	}

	void encolar(Cancion c) {
		if (estaLlena()) {
			cout << "La cola ya tiene 5 canciones.  No se puede encolar mas." << endl;
			return;
		}

		Nodo* nuevo = new Nodo(c);

		if (estaVacia()) {
			inicio = nuevo;
			fin = nuevo;
		}
		else {
			fin->siguiente = nuevo;
			fin = nuevo;
		}

		cantidad++;
		cout << "Cancion encolada correctamente. " << endl;
	}
	void desencolar() {
		if (estaVacia()) {
			cout << "La cola esta vacia." << endl;
			return;
		}


		Nodo* aux = inicio;
		cout << "Cancion desencolada: " << endl;
		aux->dato.mostrar();

		inicio = inicio->siguiente;
		delete aux;
		cantidad--;

		if (inicio == NULL) {
			fin = NULL;
		}
	}
	void mostrarCola() {
		if (estaVacia()) {
			cout << "La cola esta Vacia." << endl;
			return;
		}

		Nodo* aux = inicio;
		cout << "----------Canciones en la cola----------" << endl;
		while (aux != NULL) {
			aux->dato.mostrar();
			cout << "-----------------------" << endl;
			aux = aux->siguiente;
		}
	}
	int getCantidad() {
		return cantidad;
	}
};
