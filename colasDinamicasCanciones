#pragma once
#include <iostream>
#include <string>
using namespace std;

class Cancion
{
private:
	int codigo;
	string titulo;
	string artista;
	double duracion; 
	string genero;
public:
	Cancion() {
		codigo = 0;
		titulo = "";
		string artista = "";
		duracion = 0;
		genero = "";
	}
	
	Cancion(int c, string t, string a, double d, string g) {
		codigo = c;
		titulo = t;
		artista = a;
		duracion = d;
		genero = g;
	}

	void setTitulo(string t) {
		titulo = t;
	}
	
	void setArtista(string a) {
		artista = a;
	}

	void setDuracion(double d) {
		duracion = d;
	}

	string getTitulo() {
		return titulo;
	}
	string getArtista() {
		return artista;
	}
	double getDuracion() {
		return duracion;
	}

	void mostrar() {
		cout << "Codigo: " << codigo << endl;
		cout << "Titulo: " << titulo << endl;
		cout << "Artista: " << artista << endl;
		cout << "Duracion: " << duracion << "minutos" << endl;
		cout << "Genero: " << genero << endl;
	}


};

