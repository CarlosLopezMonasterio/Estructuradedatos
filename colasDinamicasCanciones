#include <iostream>
#include "Cola.h"
using namespace std;

int main()
{
    Cola cola;
    int opcion;
    int codigo;
    string titulo, artista, genero;
    double duracion;

    do {
        cout << "==========MENU==========" << endl;
        cout << "1. Encolar cancion" << endl;
        cout << "2. Desencolar cancion" << endl;
        cout << "3. Mostrar canciones" << endl;
        cout << "4. Salir" << endl;
        cout << "Opcion: ";
        cin >> opcion;
        cin.ignore();

        switch (opcion) {
        case 1:
            if (cola.estaLlena()) {
                cout << "Ya se encolaron 5 canciones." << endl;
            }
            else {
                cout << "Codigo: ";
                cin >> codigo;
                cin.ignore();
                
                cout << "Ingrese el titulo: ";
                getline(cin, titulo);

                cout << "Ingrese el artista: ";
                getline(cin, artista);

                cout << "Ingrese la duracion en minutos: ";
                cin >> duracion;
                cin.ignore();

                cout << "Genero: ";
                getline(cin, genero);
                
                Cancion c(codigo, titulo, artista, duracion, genero);
                cola.encolar(c);
            }
            break;
        case 2: 
            cola.desencolar();
            break;
        case 3:
            cola.mostrarCola();
            break;
        case 4:
            cout << "Saliendo del programa..." << endl;
            break;

        default:
            cout << "Opcion invalida. " << endl;
        }

    } while (opcion != 4);
    return 0;

}

