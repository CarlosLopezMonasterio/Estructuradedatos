===============Pila.h==============
#define MAX 100
typedef int TipoDato;
#pragma once
class Pila
{
private:
    int pila[MAX];
    int cima;

public:
    Pila();
    bool Apilar(TipoDato& elemento);
    bool Desapilar();
    bool CimaPila(TipoDato& elemento);
    void LimpiarPila();
    void VerPila();
    bool PilaVacia();
    bool Iguales(Pila p);

};

=================Pila.cpp=================
#include "Pila.h"
#include <iostream>

using namespace std;

Pila::Pila()
{
    cima = -1;
}

bool Pila::Apilar(TipoDato& elemento)
{
    bool res;
    if (cima == MAX - 1)
    {
        cout << "Desbordamiento de Pila (Overflow)" << endl;
        res = false;
    }
    else

    {
        cima++;
        pila[cima] = elemento;
        res = true;
    }
    return res;


}

bool Pila::Desapilar()
{
    bool res;
    if (cima == -1)
    {
        cerr << "Se esta intentando quitar un elemento de una pila vacia (underflow)" << endl;
        res = false;
    }
    else

    {
        cima--;
        res = true;
    }
    return res;


}

void Pila::VerPila()
{
    if (PilaVacia()) 
    {
        cout << "La pila esta vacia." << endl;
        return;
    }
    cout << "Contenido de la pila: " << endl;
    for (int i = 0; i <= cima; i++)
        cout << pila[i] << endl;

}


bool Pila::CimaPila(TipoDato& elemento)
{
    if (PilaVacia())
    {
        cerr << "Pila vacia (underflow)" << endl;
        return false;
    }   
    elemento = pila[cima];
    return true;
   
}

bool Pila::PilaVacia()
{
    return cima == -1;
}

void Pila::LimpiarPila()
{
    cima = -1;
}


bool Pila::Iguales(Pila p)
{
    if (cima != p.cima) return false;

    for(int i= 0; i <= cima ; i++)
    {
        if (pila[i] != p.pila[i])
            return false;
    }
    return true;
}


