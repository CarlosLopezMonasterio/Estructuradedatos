// COLA DINÁMICA

// Clase Registro
#include <iostream>
#include <string>
using namespace std;

class Dato {
public:
    double codigo;
    string nombreCompleto;
    string especialidad;
};
// Clase Nodo
#include <iostream>
#include "Dato.h"
using namespace std;

class Nodo {
public:
    Dato info;
    Nodo* siguiente;
};
// Clase Cola
#include <iostream>
#include <string>
using namespace std;

class Cola {
    Nodo* primero;
    Nodo* ultimo;

public:
    Cola();
    void encolar();
    void desencolar();
    void mostrar();
    void vacia();
};
// Cola.cpp
#include <iostream>
#include <string>
#include <stdlib.h>
#include "Nodo.h"
#include "Cola.h"

using namespace std;

Cola::Cola() {
    primero = NULL;
    ultimo = NULL;
}

void Cola::encolar() {
    Nodo* nuevo = new Nodo;

    system("cls");
    cout << "Ingrese codigo: ";
    cin >> nuevo->info.codigo;

    cout << "Ingrese nombre: ";
    cin.ignore();
    getline(cin, nuevo->info.nombreCompleto);

    cout << "Ingrese carrera: ";
    getline(cin, nuevo->info.especialidad);

    nuevo->siguiente = NULL;

    if (primero == NULL) {
        primero = ultimo = nuevo;
    }
    else {
        ultimo->siguiente = nuevo;
        ultimo = nuevo;
    }

    cout << "\nRegistro agregado correctamente.\n";
    system("pause");
}

void Cola::desencolar() {
    if (primero == NULL) {
        system("cls");
        cout << "\nNo existen elementos en la cola.\n\n";
        system("pause");
    }
    else {
        Nodo* auxiliar = primero;

        system("cls");
        cout << "Registro eliminado:\n";
        cout << auxiliar->info.codigo << " - "
             << auxiliar->info.nombreCompleto << " - "
             << auxiliar->info.especialidad << endl;

        primero = primero->siguiente;

        if (primero == NULL) {
            ultimo = NULL;
        }

        delete auxiliar;

        system("pause");
    }
}

void Cola::mostrar() {
    Nodo* recorrido = primero;

    if (primero == NULL) {
        system("cls");
        cout << "\nLa estructura se encuentra vacia.\n\n";
        system("pause");
    }
    else {
        system("cls");
        cout << "Contenido de la cola:\n\n";

        while (recorrido != NULL) {
            cout << recorrido->info.codigo << " - "
                 << recorrido->info.nombreCompleto << " - "
                 << recorrido->info.especialidad << endl;

            recorrido = recorrido->siguiente;
        }

        system("pause");
    }
}

void Cola::vacia() {
    system("cls");

    if (primero == NULL)
        cout << "No hay elementos registrados.\n";
    else
        cout << "La cola contiene elementos.\n";

    system("pause");
}
// main.cpp
#include <iostream>
#include <string>
#include <stdlib.h>
#include "Nodo.h"
#include "Cola.h"

using namespace std;

int main() {
    Cola cola;
    int opc;

    do {
        system("cls");

        cout << "===== COLA ENLAZADA =====\n";
        cout << "1. Encolar elemento\n";
        cout << "2. Desencolar elemento\n";
        cout << "3. Mostrar cola\n";
        cout << "4. Verificar si esta vacia\n";
        cout << "0. Finalizar\n";

        cout << "\nSeleccione una opcion: ";
        cin >> opc;

        switch (opc) {
        case 1:
            cola.encolar();
            break;
        case 2:
            cola.desencolar();
            break;
        case 3:
            cola.mostrar();
            break;
        case 4:
            cola.vacia();
            break;
        case 0:
            cout << "Programa finalizado.\n";
            break;
        default:
            cout << "Opcion no valida.\n";
            system("pause");
        }

    } while (opc != 0);

    return 0;
}
