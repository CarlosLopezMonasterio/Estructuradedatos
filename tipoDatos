// -------------------------------
// ESTRUCTURA DEFINIDA POR USUARIO
// -------------------------------
struct Persona {
    string nombre;
    int edad;
};

// ===============================
// PROGRAMA PRINCIPAL
// ===============================
int main() {

    int edad;
    float altura;
    char inicial;
    bool esEstudiante;

    string nombreUsuario;
    int notas[3] = {80, 90, 100};

    Persona persona;

    cout << "Ingrese su nombre: ";
    cin >> nombreUsuario;

    cout << "Ingrese su edad: ";
    cin >> edad;

    cout << "Ingrese su altura: ";
    cin >> altura;

    cout << "Ingrese inicial del apellido: ";
    cin >> inicial;

    esEstudiante = true;

    persona.nombre = nombreUsuario;
    persona.edad = edad;

    cout << "\n--- DATOS INGRESADOS ---\n";
    cout << "Nombre: " << persona.nombre << endl;
    cout << "Edad: " << persona.edad << endl;
    cout << "Altura: " << altura << endl;
    cout << "Inicial: " << inicial << endl;
    cout << "Estudiante: " << esEstudiante << endl;
    cout << "Primera nota: " << notas[0] << endl;

    return 0;
}
