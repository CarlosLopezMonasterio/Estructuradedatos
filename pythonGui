import tkinter as tk

# Función que se activa al presionar el botón
def mostrar_saludo():
    usuario = campo_nombre.get()  # Obtiene el nombre ingresado
    resultado.config(text="Hola, " + usuario)

# Crear la ventana principal
app = tk.Tk()
app.title("Interfaz Gráfica")
app.geometry("300x200")

# Etiqueta de entrada
texto_nombre = tk.Label(app, text="Escriba su nombre:")
texto_nombre.pack()

# Campo de texto
campo_nombre = tk.Entry(app)
campo_nombre.pack()

# Botón de acción
btn_saludo = tk.Button(app, text="Mostrar saludo", command=mostrar_saludo)
btn_saludo.pack()

# Etiqueta para visualizar el mensaje
resultado = tk.Label(app, text="")
resultado.pack()

# Iniciar la aplicación
app.mainloop()
