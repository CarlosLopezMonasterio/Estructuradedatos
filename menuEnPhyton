def factorial(num):
    if num == 0 or num == 1:
        return 1
    return num * factorial(num - 1)


def suma_impares(n):
    if n <= 0:
        return 0
    if n % 2 != 0:
        return n + suma_impares(n - 1)
    else:
        return suma_impares(n - 1)


def suma_naturales(n):
    if n <= 0:
        return 0
    return n + suma_naturales(n - 1)


while True:
    print("\n--- MENÚ ---")
    print("1. Calcular factorial")
    print("2. Sumar números impares")
    print("3. Sumar números naturales")
    print("0. Salir")

    opcion = input("Seleccione una opción: ")

    if opcion == "1":
        numero = int(input("Ingrese un número: "))
        print(f"El factorial de {numero} es: {factorial(numero)}")

    elif opcion == "2":
        numero = int(input("Ingrese un número límite: "))
        print(f"La suma de impares hasta {numero} es: {suma_impares(numero)}")

    elif opcion == "3":
        numero = int(input("Ingrese un número: "))
        print(f"La suma de los números naturales hasta {numero} es: {suma_naturales(numero)}")

    elif opcion == "0":
        print("Saliendo del programa...")
        break

    else:
        print("Opción no válida.")
