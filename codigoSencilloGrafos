#include <iostream>
using namespace std;

int main() {
    int n = 4; // Número de nodos
    // Matriz de n x n inicializada en 0
    int matriz[4][4] = {0};

    // Representamos una conexión entre nodo 0 y nodo 1
    matriz[0][1] = 1;
    matriz[1][0] = 1;

    // Conexión entre nodo 1 y nodo 2
    matriz[1][2] = 1;
    matriz[2][1] = 1;

    // Mostrar la matriz
    cout << "Matriz de Adyacencia:" << endl;
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cout << matriz[i][j] << " ";
        }
        cout << endl;
    }

    return 0;
}
